generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AgentKnowledge {
  id        String   @id @default(uuid())
  doctorId  String
  agentType String
  category  String   @default("general")
  knowledge String
  source    String?
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  User      User     @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, agentType])
}

model ChatSession {
  id        String   @id @default(uuid())
  doctorId  String
  patientId String?
  agentType String
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [doctorId], references: [id])
  Patient   Patient? @relation(fields: [patientId], references: [id])

  @@index([doctorId])
  @@index([patientId])
}

model Diagnosis {
  id              String        @id @default(uuid())
  medicalRecordId String
  code            String?
  description     String
  severity        String?
  diagnosedAt     DateTime
  createdAt       DateTime      @default(now())
  MedicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  @@index([medicalRecordId])
}

model File {
  id            String          @id @default(uuid())
  fileName      String
  fileType      String
  fileSize      Int
  fileUrl       String
  publicId      String
  metadata      Json?
  status        FileStatus      @default(PENDING)
  patientId     String
  doctorId      String
  createdAt     DateTime        @default(now())
  User          User            @relation(fields: [doctorId], references: [id])
  Patient       Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Inference     Inference[]
  MedicalRecord MedicalRecord[]

  @@index([doctorId])
  @@index([patientId])
}

model Hospital {
  id                 String             @id @default(uuid())
  name               String
  email              String             @unique
  phone              String?
  address            String?
  subscriptionPlan   String             @default("basic")
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  billingPhoneNumber String?
  monthlyFee         Float              @default(5000)
  trialEndsAt        DateTime?
  lastPaymentDate    DateTime?
  nextBillingDate    DateTime?
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  Patient            Patient[]
  Payment            Payment[]
  User               User[]

  @@index([subscriptionStatus])
}

model Inference {
  id            String          @id @default(uuid())
  fileId        String
  inferenceType String
  inputData     Json
  outputData    Json?
  confidence    Float?
  status        InferenceStatus @default(PENDING)
  error         String?
  doctorId      String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  User          User?           @relation(fields: [doctorId], references: [id])
  File          File            @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([fileId])
}

model LabResult {
  id              String        @id @default(uuid())
  medicalRecordId String
  testName        String
  testValue       String
  unit            String?
  referenceRange  String?
  isAbnormal      Boolean       @default(false)
  performedAt     DateTime
  createdAt       DateTime      @default(now())
  MedicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  @@index([medicalRecordId])
}

model MedicalRecord {
  id             String      @id @default(uuid())
  patientId      String
  fileId         String
  recordDate     DateTime
  recordType     String
  chiefComplaint String?
  symptoms       String[]
  vitalSigns     Json?
  physicalExam   String?
  medications    Json?
  allergies      String[]
  familyHistory  String?
  socialHistory  String?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  Diagnosis      Diagnosis[]
  LabResult      LabResult[]
  File           File        @relation(fields: [fileId], references: [id], onDelete: Cascade)
  Patient        Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([patientId])
}

model Patient {
  id                  String          @id @default(uuid())
  name                String
  email               String?
  phone               String?
  dateOfBirth         DateTime?
  gender              Gender?
  medicalRecordNumber String?
  notes               String?
  doctorId            String
  hospitalId          String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  ChatSession         ChatSession[]
  File                File[]
  MedicalRecord       MedicalRecord[]
  User                User            @relation(fields: [doctorId], references: [id])
  Hospital            Hospital?       @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([hospitalId])
}

model Payment {
  id                 String        @id @default(uuid())
  hospitalId         String
  amount             Float
  phoneNumber        String
  merchantRequestId  String?
  checkoutRequestId  String        @unique
  mpesaReceiptNumber String?       @unique
  transactionDate    DateTime?
  status             PaymentStatus @default(PENDING)
  resultCode         Int?
  resultDesc         String?
  billingPeriodStart DateTime?
  billingPeriodEnd   DateTime?
  metadata           Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  Hospital           Hospital      @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([hospitalId])
  @@index([status])
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  passwordHash   String
  name           String
  role           UserRole         @default(DOCTOR)
  hospitalId     String?          // Required for HOSPITAL_ADMIN and DOCTOR
  isActive       Boolean          @default(true)
  lastLogin      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  AgentKnowledge AgentKnowledge[]
  ChatSession    ChatSession[]
  File           File[]
  Inference      Inference[]
  Patient        Patient[]
  Hospital       Hospital?        @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([hospitalId])
  @@index([role])
}

model agent_knowledge {
  id         String   @id
  doctor_id  String
  agent_type String
  category   String
  title      String
  content    String
  is_active  Boolean  @default(true)
  priority   Int      @default(0)
  metadata   Json?
  created_at DateTime @default(now())
  updated_at DateTime
  users      users    @relation(fields: [doctor_id], references: [id], onDelete: Cascade)

  @@index([agent_type])
  @@index([category])
  @@index([doctor_id])
}

model agent_suggestions {
  id              String   @id
  chat_session_id String
  from_agent      String
  to_agent        String
  reason          String
  symptoms        String[]
  confidence      Decimal  @db.Decimal(5, 4)
  was_accepted    Boolean?
  created_at      DateTime @default(now())

  @@index([chat_session_id])
  @@index([from_agent])
  @@index([to_agent])
}

model diagnoses {
  id                String          @id
  medical_record_id String
  diagnosis_code    String?
  diagnosis_name    String
  severity          String?
  status            String?
  notes             String?
  created_at        DateTime        @default(now())
  medical_records   medical_records @relation(fields: [medical_record_id], references: [id], onDelete: Cascade)

  @@index([diagnosis_code])
  @@index([medical_record_id])
}

model files {
  id              String            @id
  patient_id      String
  doctor_id       String
  file_name       String
  file_path       String
  file_type       String
  file_size       Int
  upload_date     DateTime          @default(now())
  metadata        Json?
  created_at      DateTime          @default(now())
  users           users             @relation(fields: [doctor_id], references: [id], onDelete: Cascade)
  patients        patients          @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  inferences      inferences[]
  medical_records medical_records[]

  @@index([doctor_id])
  @@index([patient_id])
}

model inferences {
  id                 String   @id
  file_id            String
  patient_id         String
  inference_type     String
  input_data         Json?
  output_data        Json?
  confidence_score   Decimal? @db.Decimal(5, 4)
  error_message      String?
  processing_time_ms Int?
  created_at         DateTime @default(now())
  updated_at         DateTime
  files              files    @relation(fields: [file_id], references: [id], onDelete: Cascade)
  patients           patients @relation(fields: [patient_id], references: [id], onDelete: Cascade)

  @@index([file_id])
  @@index([patient_id])
}

model lab_results {
  id                String          @id
  medical_record_id String
  test_name         String
  test_code         String?
  value             String
  unit              String?
  reference_range   String?
  status            String?
  notes             String?
  created_at        DateTime        @default(now())
  medical_records   medical_records @relation(fields: [medical_record_id], references: [id], onDelete: Cascade)

  @@index([medical_record_id])
  @@index([test_name])
}

model medical_records {
  id          String        @id
  patient_id  String
  file_id     String?
  record_type String
  record_date DateTime
  data        Json
  source      String?
  created_at  DateTime      @default(now())
  updated_at  DateTime
  diagnoses   diagnoses[]
  lab_results lab_results[]
  files       files?        @relation(fields: [file_id], references: [id])
  patients    patients      @relation(fields: [patient_id], references: [id], onDelete: Cascade)

  @@index([file_id])
  @@index([patient_id])
  @@index([record_date])
}

model patients {
  id                    String            @id
  doctor_id             String
  name                  String
  email                 String?
  phone                 String?
  date_of_birth         DateTime?         @db.Date
  medical_record_number String?
  notes                 String?
  created_at            DateTime          @default(now())
  updated_at            DateTime
  files                 files[]
  inferences            inferences[]
  medical_records       medical_records[]
  users                 users             @relation(fields: [doctor_id], references: [id], onDelete: Cascade)
  reports               reports[]

  @@index([doctor_id])
}

model reports {
  id              String   @id
  patient_id      String
  report_type     String
  title           String
  content         Json
  insights        String[]
  recommendations String[]
  risk_score      Decimal? @db.Decimal(5, 2)
  generated_by    String
  created_at      DateTime @default(now())
  updated_at      DateTime
  patients        patients @relation(fields: [patient_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([patient_id])
  @@index([report_type])
}

model users {
  id              String            @id
  email           String            @unique
  password_hash   String
  name            String
  created_at      DateTime          @default(now())
  updated_at      DateTime
  agent_knowledge agent_knowledge[]
  files           files[]
  patients        patients[]

  @@index([email])
}

enum FileStatus {
  PENDING
  UPLOADED
  PROCESSING
  ANALYZED
  PROCESSED
  FAILED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum InferenceStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  TIMEOUT
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  EXPIRED
  SUSPENDED
  PENDING_PAYMENT
}

enum UserRole {
  SUPER_ADMIN
  HOSPITAL_ADMIN
  DOCTOR
}
