generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SymptomLog {
  id             String   @id @default(cuid())
  logDate        DateTime
  symptoms       String
  mood           String?
  energy         String?
  sexualActivity String?
  medication     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([logDate])
}
