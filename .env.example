# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="your-generated-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-generated-key-here"

# Database Seeding (development only)
# Default password for seed admin if not set, should NOT be used in production
SEED_ADMIN_PASSWORD="SuperSecurePassword123!"

# AI — using GitHub Models (free, no billing needed)
# Get token at: github.com/settings/tokens (no scopes required)
AI_PROVIDER="openai"
OPENAI_API_KEY="ghp_your_github_token_here"
OPENAI_MODEL="openai/gpt-4o-mini"
OPENAI_BASE_URL="https://models.github.ai"

# Optional (enable later)
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
# GOOGLE_APPLICATION_CREDENTIALS=""
# GOOGLE_CLOUD_VISION_API_KEY=""
